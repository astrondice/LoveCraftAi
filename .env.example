# ─────────────────────────────────────────────────────────────────
# LoveCraft.ai — Environment Variables
# Copy this file to .env.local and fill in your credentials
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (Hono API / Cloudflare Worker)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Cloudflare R2 ─────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=lovecraft-assets
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_URL=https://pub-xxxx.r2.dev  # Or your custom domain

# ── App ───────────────────────────────────────────────────────────
# ── App ───────────────────────────────────────────────────────────
# VITE_APP_URL — used ONLY as an SSR server-side fallback.
#   In the browser, window.location.origin is always used instead
#   (automatically correct in both dev and production).
# On Vercel: set this to your production domain, e.g.:
VITE_APP_URL=https://love-craft-ai.vercel.app
# Locally (dev server runs on 8080):
# VITE_APP_URL=http://localhost:8080

# VITE_API_URL — defaults to /api (relative, same origin).
#   Only set this if your Hono Worker runs on a different domain.
VITE_API_URL=/api

# ── OAuth (configured in Supabase dashboard, not here) ───────────
# Google: https://supabase.com/dashboard/project/_/auth/providers
# GitHub: https://supabase.com/dashboard/project/_/auth/providers
